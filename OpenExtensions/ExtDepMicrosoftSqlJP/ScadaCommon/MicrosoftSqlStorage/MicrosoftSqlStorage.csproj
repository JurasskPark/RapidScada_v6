<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <RootNamespace>Scada.Storages.MicrosoftSqlStorage</RootNamespace>
    <Version>6.4.0</Version>
    <Authors>Mikhail Shiryaev, Yuriy Pradius</Authors>
    <Company>Rapid Software LLC</Company>
    <Product>Rapid SCADA</Product>
    <Copyright>Copyright © 2026</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.SqlClient" Version="6.1.0" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="ScadaCommon">
      <HintPath>..\..\Libraries\ScadaCommon.dll</HintPath>
    </Reference>
    <Reference Include="ScadaCommon.Log">
      <HintPath>..\..\Libraries\ScadaCommon.Log.dll</HintPath>
    </Reference>
  </ItemGroup>

  <Target Name="CopyPackageDependenciesToStorageSubdir" AfterTargets="Build">
    <ItemGroup>
      <PackageDependencyDll Include="@(ReferenceCopyLocalPaths)" Condition="'%(ReferenceCopyLocalPaths.NuGetPackageId)' != '' and '%(ReferenceCopyLocalPaths.Extension)' == '.dll'" />
      <PackageDependencyDll Include="@(RuntimeCopyLocalItems)" Condition="'%(RuntimeCopyLocalItems.NuGetPackageId)' != '' and '%(RuntimeCopyLocalItems.Extension)' == '.dll'" />
    </ItemGroup>

    <Copy SourceFiles="@(PackageDependencyDll)" DestinationFiles="@(PackageDependencyDll->'$(OutDir)$(AssemblyName)\%(DestinationSubDirectory)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />

    <Copy SourceFiles="$(OutDir)$(AssemblyName)\runtimes\win\lib\net8.0\Microsoft.Data.SqlClient.dll" DestinationFolder="$(OutDir)$(AssemblyName)" SkipUnchangedFiles="true" Condition="Exists('$(OutDir)$(AssemblyName)\runtimes\win\lib\net8.0\Microsoft.Data.SqlClient.dll')" />

    <Copy SourceFiles="$(OutDir)$(AssemblyName)\runtimes\win-x64\native\Microsoft.Data.SqlClient.SNI.dll" DestinationFolder="$(OutDir)$(AssemblyName)" SkipUnchangedFiles="true" Condition="Exists('$(OutDir)$(AssemblyName)\runtimes\win-x64\native\Microsoft.Data.SqlClient.SNI.dll')" />
  </Target>

</Project>
