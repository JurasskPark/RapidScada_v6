		<EnableDynamicLoading>true</EnableDynamicLoading>
		<RootNamespace>Scada.Comm.Drivers.DrvFtpJP.Logic</RootNamespace>
		<Version>6.4.1.1</Version>
		<Authors>Yuriy Pradius</Authors>
		<Company>Pradius Y.A.</Company>
